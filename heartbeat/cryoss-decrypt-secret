#!/usr/bin/env python3
"""
cryoss-decrypt-secret — Helper Fernet pour le runner Cryoss.

Lit /etc/cryoss/master_key (mode 0600) et déchiffre un token au format
`enc:v1:<urlsafe-b64>` reçu depuis le runner.

Usage (appelé depuis cryoss-command-runner.sh) :
    PLAIN=$(CRYOSS_TOKEN="$param" /usr/local/bin/cryoss-decrypt-secret) || {
        send_ack "error" "decrypt failed"; exit 1
    }

Conventions :
- Le cleartext est imprimé sur stdout (pas de newline final implicite).
- Toute erreur → exit 1 + message court sur stderr (jamais le cleartext).
- La clé est chargée à chaque invocation (pas de cache) — l'opérateur peut
  remplacer le fichier sans redémarrer rien.
"""

from __future__ import annotations

import os
import sys


MASTER_KEY_PATH = "/etc/cryoss/master_key"
TOKEN_PREFIX = "enc:v1:"


def _err(msg: str) -> None:
    """Imprime un message d'erreur court sur stderr et exit 1.
    Ne contient jamais le cleartext ni la master key.
    """
    print(f"cryoss-decrypt-secret: {msg}", file=sys.stderr)
    sys.exit(1)


def main() -> None:
    token = os.environ.get("CRYOSS_TOKEN", "")
    if not token:
        _err("missing CRYOSS_TOKEN env var")

    if not token.startswith(TOKEN_PREFIX):
        _err(f"missing prefix {TOKEN_PREFIX}")

    payload = token[len(TOKEN_PREFIX):]

    try:
        with open(MASTER_KEY_PATH, "rb") as fh:
            key = fh.read().strip()
    except FileNotFoundError:
        _err("missing Cryoss master key")
    except PermissionError:
        _err("permission denied reading master key")

    try:
        from cryptography.fernet import Fernet, InvalidToken
    except ImportError:
        _err("python3-cryptography not installed")

    try:
        plain = Fernet(key).decrypt(payload.encode("utf-8"))
    except InvalidToken:
        _err("invalid token (bad key or tampered ciphertext)")
    except ValueError:
        _err("malformed key")

    sys.stdout.buffer.write(plain)
    sys.stdout.flush()


if __name__ == "__main__":
    main()
